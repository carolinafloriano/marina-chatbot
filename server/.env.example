# Copie este ficheiro para .env e preencha com a sua chave.
# Nunca comite o ficheiro .env real — ele contém segredos.
ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# Defina como "true" para testar a interface com respostas simuladas,
# sem chamar a API da Anthropic e sem custos. Nesse caso ANTHROPIC_API_KEY
# pode ficar vazia. Ver server/demoResponses.js.
DEMO_MODE=false
